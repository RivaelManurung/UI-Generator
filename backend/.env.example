APP_ENV=development
PORT=8080
DATABASE_URL=postgres://dashboardcraft:dashboardcraft@localhost:5433/dashboardcraft?sslmode=disable
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=replace-with-at-least-32-random-characters
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Midtrans (credit top-up). Get keys from the Midtrans dashboard.
MIDTRANS_ENV=sandbox
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
