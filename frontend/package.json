{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:routes:generate": "tsx tests/route-smoke/generate-routes.ts",
    "test:routes": "npm run test:routes:generate && playwright test tests/route-smoke/all-pages.spec.ts",
    "test:links": "npm run test:routes:generate && playwright test tests/route-smoke/link-check.spec.ts",
    "test:a11y": "npm run test:routes:generate && playwright test tests/route-smoke/accessibility.spec.ts",
    "test:prod": "next build && npm run test:routes:generate && playwright test"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tanstack/react-query": "^5.101.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "next": "^16.2.7",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.77.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "fast-glob": "^3.3.3",
    "shadcn": "^4.10.0",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
